# Copy to `.env.local` (recommended) or `.env` and fill in values.
#
# Keep secrets out of git. This file is safe to commit as a template.
#
# Example:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI providers (server-side only) ---
# Choose default provider used by `services/aiservice.tsx` (optional).
# AI_PROVIDER=openai
#
# Optional: protect `POST /api/ai/complete` with a bearer token.
# If set, clients must send: `Authorization: Bearer <token>`
# AI_API_TOKEN=
#
# OpenAI (recommended for MVP)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com
#
# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01

